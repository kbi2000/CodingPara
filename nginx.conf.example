server {
  listen 80;
  server_name www.codingpara.com codingpara.com;
  if ($host = codingpara.com) { return 301 https://www.codingpara.com$request_uri; }
  location / { proxy_pass http://127.0.0.1:3000; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; }
  location = /api/health { proxy_pass http://127.0.0.1:3000; }
}
